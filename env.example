# MongoDB Database URL
MONGODB_URI=mongodb://localhost:27017

# Google OAuth Credentials
# Retrieve these from Google Cloud Console (https://console.cloud.google.com)
# Make sure to configure the authorized redirect URI to:
# ${NEXT_PUBLIC_BASE_URL}/api/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Application URL (used for redirect URIs and absolute links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
