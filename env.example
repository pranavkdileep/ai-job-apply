# MongoDB Database URL
MONGODB_URI=mongodb://localhost:27017

# Google OAuth Credentials
# Retrieve these from Google Cloud Console (https://console.cloud.google.com)
# Make sure to configure the authorized redirect URI to:
# ${NEXT_PUBLIC_BASE_URL}/api/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Application URL (used for redirect URIs and absolute links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public LLM API (OpenAI-compatible, server-side)
# Users can generate emails without their own API key
# Leave commented out to disable the Public API option
# PUBLIC_API_BASE_URL=https://api.example.com/v1
# PUBLIC_API_KEY=your-api-key
# PUBLIC_API_MODEL=gpt-4o-mini
